<%- include('../partials/sidebar_admin') %>

<main class="flex-1 h-screen overflow-y-auto bg-brand-bg relative flex flex-col min-w-0">
  <header class="flex items-center justify-between px-8 py-4 bg-white/92 backdrop-blur-md border-b border-brand-border sticky top-0 z-40">
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-brand-navy">Cuotas por Vencer</h1>
      <p class="text-[13px] text-brand-muted mt-0.5">Cuotas con vencimiento en los <strong class="text-brand-warning font-bold">próximos 5 días</strong> — <strong class="font-bold text-brand-text"><%= user.name %></strong></p>
    </div>
    <div class="flex items-center gap-4">
      <img src="<%= user.avatar %>" alt="Avatar" class="w-[38px] h-[38px] rounded-full border-2 border-brand-gold object-cover">
    </div>
  </header>

  <div class="p-8 max-w-[1400px] mx-auto w-full flex-1 flex flex-col gap-6">

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-brand-success-light border border-brand-success text-brand-success px-5 py-4 rounded-[12px] flex items-center gap-3 animate-in">
      <i class="ri-checkbox-circle-line text-[18px]"></i>
      <p class="text-[13px] font-medium"><%= success %></p>
    </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-brand-danger-light border border-brand-danger text-brand-danger px-5 py-4 rounded-[12px] flex items-center gap-3 animate-in">
      <i class="ri-error-warning-line text-[18px]"></i>
      <p class="text-[13px] font-medium"><%= error %></p>
    </div>
    <% } %>

    <!-- KPI strip -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 animate-in">
      <!-- Total por vencer -->
      <div class="bg-white rounded-[20px] p-6 shadow-[0_2px_8px_rgba(10,22,40,0.07)] border-l-[3px] border-l-brand-warning border border-brand-border flex items-center gap-4 hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(10,22,40,0.08)] transition-all duration-300">
        <div class="w-12 h-12 rounded-[14px] flex items-center justify-center bg-amber-50 text-amber-500 border border-amber-200">
          <i class="ri-time-line text-[22px]"></i>
        </div>
        <div>
          <p class="text-[12px] font-semibold text-brand-muted tracking-wide uppercase">Cuotas por Vencer</p>
          <p class="text-[28px] font-extrabold tracking-tight text-amber-500 mt-0.5"><%= typeof porVencer !== 'undefined' ? porVencer.length : 0 %></p>
        </div>
      </div>
      <!-- Urgentes (0-2 días) -->
      <div class="bg-white rounded-[20px] p-6 shadow-[0_2px_8px_rgba(10,22,40,0.07)] border-l-[3px] border-l-brand-danger border border-brand-border flex items-center gap-4 hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(10,22,40,0.08)] transition-all duration-300">
        <div class="w-12 h-12 rounded-[14px] flex items-center justify-center bg-brand-danger-light text-brand-danger border border-brand-danger/20">
          <i class="ri-alarm-warning-line text-[22px]"></i>
        </div>
        <div>
          <p class="text-[12px] font-semibold text-brand-muted tracking-wide uppercase">Urgentes (0–2 días)</p>
          <p class="text-[28px] font-extrabold tracking-tight text-brand-danger mt-0.5"><%= typeof urgentes !== 'undefined' ? urgentes : 0 %></p>
        </div>
      </div>
      <!-- Monto en riesgo -->
      <div class="bg-white rounded-[20px] p-6 shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex items-center gap-4 hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(10,22,40,0.08)] transition-all duration-300">
        <div class="w-12 h-12 rounded-[14px] flex items-center justify-center bg-brand-blue-light text-brand-blue">
          <i class="ri-money-dollar-circle-line text-[22px]"></i>
        </div>
        <div>
          <p class="text-[12px] font-semibold text-brand-muted tracking-wide uppercase">Monto en Riesgo</p>
          <p class="text-[20px] font-extrabold tracking-tight text-brand-blue mt-0.5">S/<%= typeof montoEnRiesgo !== 'undefined' ? montoEnRiesgo : '0.00' %></p>
        </div>
      </div>
    </div>

    <!-- Alerta principal -->
    <% if (typeof porVencer !== 'undefined' && porVencer.length > 0) { %>
    <div class="bg-amber-50/80 border-l-[4px] border-l-amber-400 border border-amber-200 px-5 py-4 rounded-[12px] flex items-start gap-3 animate-in delay-100">
      <i class="ri-error-warning-line text-amber-500 text-[22px] flex-shrink-0 mt-0.5"></i>
      <div>
        <p class="font-bold text-[14px] text-amber-700">¡Atención! <%= porVencer.length %> cuota<%= porVencer.length !== 1 ? 's' : '' %> próxima<%= porVencer.length !== 1 ? 's' : '' %> a vencer</p>
        <p class="text-[13px] text-amber-700/80 mt-0.5">Contacta a los clientes para evitar que pasen a estado <strong>Vencido</strong>. Puedes usar el botón WhatsApp en cada fila.</p>
      </div>
    </div>
    <% } %>

    <!-- Tabla -->
    <div class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex flex-col overflow-hidden animate-in delay-200">
      <div class="px-7 py-5 border-b border-brand-border flex items-center justify-between gap-4 flex-wrap">
        <div>
          <p class="text-[15px] font-bold tracking-tight text-brand-navy">Cuotas venciendo en 5 días</p>
          <p class="text-[13px] text-brand-muted mt-0.5">Ordenadas por urgencia — más próximas primero</p>
        </div>
        <div class="relative">
          <i class="ri-search-line absolute left-3 top-1/2 -translate-y-1/2 text-brand-muted text-[15px] pointer-events-none"></i>
          <input type="text" id="search" placeholder="Buscar cliente..."
            class="py-2.5 pr-3.5 pl-9 border-[1.5px] border-brand-border rounded-lg text-[13px] bg-brand-surface2 outline-none w-[220px] transition-all duration-200 text-brand-text focus:border-brand-blue focus:bg-white focus:shadow-[0_0_0_3px_rgba(27,79,216,0.1)]">
        </div>
      </div>

      <% if (typeof porVencer === 'undefined' || porVencer.length === 0) { %>
      <div class="py-16 px-6 text-center flex flex-col items-center">
        <div class="w-[68px] h-[68px] bg-brand-success-light rounded-full flex items-center justify-center text-brand-success mb-4">
          <i class="ri-checkbox-circle-line text-[32px]"></i>
        </div>
        <p class="text-[15px] font-bold text-brand-success">¡Sin vencimientos próximos!</p>
        <p class="mt-1 text-[13px] text-brand-muted">No hay cuotas que venzan en los próximos 5 días.</p>
      </div>
      <% } else { %>
      <div class="w-full overflow-x-auto">
        <table class="w-full border-collapse text-left text-[13px]">
          <thead>
            <tr class="bg-brand-surface border-b border-brand-border">
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide">#</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide">Cliente</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide">Inversionista</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide">Cuota N°</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-right">Monto Cuota</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-center">Vence</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-center">Días</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% porVencer.forEach((c, i) => {
              const dias = Number(c.dias_restantes);
              const esUrgente = dias <= 2;
              const esCritico = dias === 0;
              const fechaFmt = new Date(c.fecha_vencimiento).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
              const telLimpio = (c.cliente_telefono || '').replace(/[^0-9]/g, '');
              const msgWA = encodeURIComponent(`Hola ${c.cliente_nombre}, le recordamos que su cuota N° ${c.numero_cuota} por $${Number(c.monto_cuota).toLocaleString('es-MX',{minimumFractionDigits:2})} vence el ${fechaFmt}. Por favor realice su pago a tiempo. Gracias.`);
            %>
            <tr class="row border-b border-brand-border last:border-b-0 hover:bg-brand-surface transition-colors duration-150 <%= esUrgente ? 'bg-red-50/40' : '' %>">
              <td class="py-3.5 px-5 text-brand-muted font-medium">#<%= i + 1 %></td>
              <td class="py-3.5 px-5">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full flex items-center justify-center text-[12px] font-bold text-white <%= esUrgente ? 'bg-gradient-to-br from-brand-danger to-red-700' : 'bg-gradient-to-br from-amber-500 to-amber-700' %>">
                    <%= (c.cliente_nombre || '?').charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <span class="font-semibold text-brand-navy block"><%= c.cliente_nombre || '—' %></span>
                    <% if (c.cliente_telefono) { %><span class="text-[11px] text-brand-muted"><%= c.cliente_telefono %></span><% } %>
                  </div>
                </div>
              </td>
              <td class="py-3.5 px-5 text-brand-muted"><%= c.inversor_nombre || '—' %></td>
              <td class="py-3.5 px-5 text-center">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-brand-navy text-white text-[12px] font-bold"><%= c.numero_cuota %></span>
              </td>
              <td class="py-3.5 px-5 text-right font-bold text-brand-navy">S/<%= Number(c.monto_cuota).toLocaleString('es-MX',{minimumFractionDigits:2}) %></td>
              <td class="py-3.5 px-5 text-center text-[12px] font-medium text-brand-text"><%= fechaFmt %></td>
              <td class="py-3.5 px-5 text-center">
                <% if (esCritico) { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[12px] font-bold bg-red-100 text-red-600 border border-red-300 animate-pulse">
                    <i class="ri-alarm-warning-fill text-[12px]"></i> ¡Hoy!
                  </span>
                <% } else if (esUrgente) { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[12px] font-bold bg-brand-danger-light text-brand-danger border border-brand-danger/30">
                    <i class="ri-alarm-warning-line text-[12px]"></i> <%= dias %> días
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[12px] font-bold bg-amber-50 text-amber-600 border border-amber-200">
                    <i class="ri-time-line text-[12px]"></i> <%= dias %> días
                  </span>
                <% } %>
              </td>
              <td class="py-3.5 px-5 text-center">
                <div class="flex items-center justify-center gap-2">
                  <a href="/dashboard/prestamos/<%= c.prestamo_id %>/cronograma" title="Ver cronograma"
                    class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-surface hover:bg-brand-blue-light hover:text-brand-blue transition-colors text-brand-muted">
                    <i class="ri-calendar-line text-[15px]"></i>
                  </a>
                  <% if (telLimpio) { %>
                  <a href="https://wa.me/<%= telLimpio %>?text=<%= msgWA %>" target="_blank" title="Enviar recordatorio WhatsApp"
                    class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 hover:bg-green-100 text-green-600 transition-colors border border-green-200">
                    <i class="ri-whatsapp-line text-[16px]"></i>
                  </a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</main>

<script>
  document.getElementById('search')?.addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.row').forEach(r => {
      r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>
