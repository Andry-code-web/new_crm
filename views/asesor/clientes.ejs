<%- include('../partials/sidebar_asesor') %>

<main class="flex-1 flex flex-col h-full bg-gray-50 relative overflow-y-auto">
    <header class="flex items-center justify-between px-8 py-5 bg-white/80 backdrop-blur-md sticky top-0 z-10 border-b border-gray-100">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Clientes</h1>
            <p class="text-gray-500 text-sm mt-0.5">Consulta la información de tus clientes</p>
        </div>
    </header>

    <div class="p-8 max-w-7xl mx-auto w-full space-y-6">
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-4 bg-red-50 border border-red-200 rounded-2xl"><p class="text-red-700 font-medium"><%= error %></p></div>
        <% } %>

        <div class="grid grid-cols-3 gap-5">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg></div>
                <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total Clientes</p><p class="text-2xl font-bold text-gray-800"><%= clientes.length %></p></div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Con Préstamo</p><p class="text-2xl font-bold text-gray-800"><%= conPrestamo %></p></div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg></div>
                <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Préstamos Totales</p><p class="text-2xl font-bold text-gray-800"><%= totalPrestamos %></p></div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-8 py-5 flex items-center justify-between border-b border-gray-100">
                <h2 class="text-lg font-bold text-gray-800">Listado de Clientes</h2>
                <input type="text" id="search" placeholder="Buscar..." class="pl-9 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none w-52">
            </div>
            <% if (clientes.length === 0) { %>
            <div class="py-16 text-center"><p class="text-gray-400 font-medium">No hay clientes registrados</p></div>
            <% } else { %>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead><tr class="bg-gray-50 border-b border-gray-100">
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase">Cliente</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase">Contacto</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-400 uppercase">Préstamos</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-400 uppercase">Monto Activo</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase">Contraseña</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-50">
                        <% clientes.forEach(c => { %>
                        <tr class="hover:bg-gray-50 transition-colors row">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-indigo-500 flex items-center justify-center"><span class="text-sm font-bold text-white"><%= c.nombre.charAt(0).toUpperCase() %></span></div>
                                    <div><p class="font-semibold text-gray-800"><%= c.nombre %></p><p class="text-xs text-gray-400"><%= c.ciudad || 'Sin ciudad' %></p></div>
                                </div>
                            </td>
                            <td class="px-6 py-4"><p class="text-gray-600"><%= c.email || '—' %></p><p class="text-xs text-gray-400"><%= c.telefono || '—' %></p></td>
                            <td class="px-6 py-4 text-center"><span class="px-2.5 py-1 bg-blue-50 text-blue-700 rounded-full text-xs font-semibold"><%= c.num_prestamos || 0 %></span></td>
                            <td class="px-6 py-4 text-right font-semibold text-gray-800">$<%= Number(c.monto_activo || 0).toLocaleString('es-MX', {minimumFractionDigits: 2}) %></td>
                            <td class="px-6 py-4">
                                <% if (c.user_password) { %>
                                <div class="flex items-center gap-1.5">
                                    <span class="font-mono text-[13px] text-gray-700 tracking-wider ase-pwd-text-<%= c.id %>">••••••••</span>
                                    <span class="font-mono text-[13px] text-gray-700 tracking-wider ase-pwd-value-<%= c.id %> hidden"><%= c.user_password %></span>
                                    <button type="button" onclick="toggleAsePwd(<%= c.id %>)" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-gray-100 transition-colors text-gray-400 hover:text-gray-700" title="Ver contraseña">
                                        <svg class="ase-eye-off-<%= c.id %>" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                                        <svg class="ase-eye-on-<%= c.id %> hidden" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </button>
                                </div>
                                <% } else { %>
                                <span class="text-gray-400 text-xs">Sin usuario</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </div>
</main>

<script>
    document.getElementById('search')?.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.row').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    function toggleAsePwd(id) {
        const dots   = document.querySelector('.ase-pwd-text-' + id);
        const val    = document.querySelector('.ase-pwd-value-' + id);
        const eyeOff = document.querySelector('.ase-eye-off-' + id);
        const eyeOn  = document.querySelector('.ase-eye-on-' + id);
        const hidden = val.classList.contains('hidden');
        dots.classList.toggle('hidden', hidden);
        val.classList.toggle('hidden', !hidden);
        eyeOff.classList.toggle('hidden', hidden);
        eyeOn.classList.toggle('hidden', !hidden);
    }
</script>
