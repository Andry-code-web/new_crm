<%- include('../partials/sidebar_asesor') %>

<main class="flex-1 flex flex-col h-full bg-gray-50 relative overflow-y-auto">
    <header class="flex items-center justify-between px-8 py-5 bg-white/80 backdrop-blur-md sticky top-0 z-10 border-b border-gray-100">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Inversionistas</h1>
            <p class="text-gray-500 text-sm mt-0.5">Consulta los fondos e inversionistas disponibles</p>
        </div>
    </header>

    <div class="p-8 max-w-7xl mx-auto w-full space-y-6">
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-4 bg-red-50 border border-red-200 rounded-2xl"><p class="text-red-700 font-medium"><%= error %></p></div>
        <% } %>

        <div class="grid grid-cols-3 gap-5">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total</p><p class="text-2xl font-bold text-gray-800"><%= inversionistas.length %></p></div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Con Préstamos</p><p class="text-2xl font-bold text-gray-800"><%= activos %></p></div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
                <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg></div>
                <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Monto Total</p><p class="text-2xl font-bold text-gray-800">S/<%= montoTotal %></p></div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-8 py-5 flex items-center justify-between border-b border-gray-100">
                <h2 class="text-lg font-bold text-gray-800">Listado de Inversionistas</h2>
                <input type="text" id="search" placeholder="Buscar..." class="pl-9 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 outline-none w-52">
            </div>
            <% if (inversionistas.length === 0) { %>
            <div class="py-16 text-center"><p class="text-gray-400 font-medium">No hay inversionistas registrados</p></div>
            <% } else { %>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead><tr class="bg-gray-50 border-b border-gray-100">
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase">Inversionista</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase">Empresa</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase">Contacto</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-400 uppercase">Préstamos</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-400 uppercase">Monto Invertido</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-50">
                        <% inversionistas.forEach(i => { %>
                        <tr class="hover:bg-gray-50 transition-colors row">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center"><span class="text-sm font-bold text-white"><%= i.nombre.charAt(0).toUpperCase() %></span></div>
                                    <span class="font-semibold text-gray-800"><%= i.nombre %></span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-600"><%= i.empresa || '—' %></td>
                            <td class="px-6 py-4"><p class="text-gray-600"><%= i.email || '—' %></p><p class="text-xs text-gray-400"><%= i.telefono || '—' %></p></td>
                            <td class="px-6 py-4 text-center"><span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 rounded-full text-xs font-semibold"><%= i.num_prestamos || 0 %></span></td>
                            <td class="px-6 py-4 text-right font-semibold text-gray-800">S/<%= Number(i.monto_invertido || 0).toLocaleString('es-MX', {minimumFractionDigits: 2}) %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </div>
</main>

<script>
    document.getElementById('search')?.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.row').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
</script>
