<%- include('../partials/sidebar_cliente') %>

  <main class="flex-1 h-screen overflow-y-auto bg-brand-bg relative flex flex-col min-w-0">

    <!-- Top Header -->
    <header
      class="flex items-center justify-between px-8 py-4 bg-white/92 backdrop-blur-md border-b border-brand-border sticky top-0 z-40">
      <div>
        <h1 class="text-[22px] font-bold tracking-tight text-brand-navy">Bienvenido, <%= cliente ?
            cliente.nombre.split(' ')[0] : user.name %></h1>
      <p class="text-[13px] text-brand-muted mt-0.5">Tu portal de préstamos hipotecarios</p>
    </div>
    <img src="<%= user.avatar %>" alt="Avatar" class="w-[38px] h-[38px] rounded-full border-2 border-brand-gold object-cover">
  </header>

  <div class="p-8 max-w-[1400px] mx-auto w-full flex-1 flex flex-col gap-6">

    <!-- Estado del préstamo -->
    <% if (!cliente) { %>
      <div class="bg-[#FFF4E5] border-l-[4px] border-l-orange-500 border border-[#FEE1BB] px-5 py-4 rounded-[12px] flex items-center gap-4 transition-opacity duration-300 animate-in">
        <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 shrink-0">
          <i class="ri-user-unfollow-line text-[20px]"></i>
        </div>
        <div>
          <p class="font-bold text-[14px] text-orange-800">Completa tu perfil</p>
          <p class="text-[13px] text-orange-700 opacity-90">Para acceder a todos los servicios, <a href="/cliente/perfil" class="font-bold hover:underline underline-offset-2">vincula tu cuenta aquí</a>.</p>
        </div>
      </div>
    <% } else if (!prestamoActivo) { %>
      <div class="bg-brand-blue-light/50 border-l-[4px] border-l-brand-blue border border-brand-blue/20 px-5 py-4 rounded-[12px] flex items-center gap-4 transition-opacity duration-300 animate-in">
        <div class="w-10 h-10 rounded-full bg-brand-blue/10 flex items-center justify-center text-brand-blue shrink-0">
          <i class="ri-information-line text-[20px]"></i>
        </div>
        <div>
          <p class="font-bold text-[14px] text-brand-blue">Sin préstamos activos</p>
          <p class="text-[13px] text-brand-text opacity-90">Contacta a tu asesor para solicitar un préstamo hipotecario.</p>
        </div>
      </div>
    <% } else { %>
      <!-- Hero Banner — Cuota Mensual -->
      <div class="bg-gradient-to-br from-brand-navy via-[#0f1e38] to-[#122046] rounded-[24px] p-8 text-white relative overflow-hidden shadow-[0_8px_32px_rgba(10,22,40,0.18)] flex flex-col xl:flex-row xl:items-center justify-between gap-6 animate-in">
        <div class="absolute -right-20 -top-20 w-80 h-80 bg-[radial-gradient(circle,rgba(212,168,67,0.2)_0%,transparent_70%)] pointer-events-none"></div>

        <div>
          <p class="text-[12px] font-bold uppercase tracking-[0.12em] text-brand-gold mb-2 flex items-center gap-1.5">
            <i class="ri-bank-card-line text-[14px]"></i> Tu cuota <%= prestamoActivo.tipo_pago %>
          </p>
          <p class="text-[44px] font-extrabold tracking-tight leading-none mb-1">
            S/<%= Number(prestamoActivo.cuota).toLocaleString('es-MX', {minimumFractionDigits: 2}) %>
            <span class="text-[20px] font-semibold text-white/50 ml-1">SOL</span>
          </p>
        </div>

        <div class="flex flex-wrap items-center gap-6 sm:gap-10 relative z-10">
          <div class="flex flex-col gap-1">
            <p class="text-[11px] font-semibold text-white/50 uppercase tracking-wide">Monto</p>
            <p class="text-[22px] font-bold text-white">S/<%= Number(prestamoActivo.monto).toLocaleString('es-MX', {minimumFractionDigits: 2}) %></p>
          </div>
          <div class="w-px h-10 bg-white/10 hidden sm:block"></div>
          <div class="flex flex-col gap-1">
            <p class="text-[11px] font-semibold text-white/50 uppercase tracking-wide">Plazo</p>
            <p class="text-[22px] font-bold text-white"><%= prestamoActivo.plazo_meses %> meses</p>
          </div>
          <div class="w-px h-10 bg-white/10 hidden sm:block"></div>
          <div class="flex flex-col gap-1">
            <p class="text-[11px] font-semibold text-white/50 uppercase tracking-wide">Estado</p>
            <p class="text-[22px] font-bold text-brand-gold capitalize"><%= prestamoActivo.estado %></p>
          </div>
        </div>

        <div class="relative z-10 flex-shrink-0">
          <a href="/cliente/prestamo?id=<%= prestamoActivo.id %>"
            class="inline-flex items-center gap-2 justify-center px-5 py-3.5 rounded-xl text-[13px] font-bold text-brand-navy bg-gradient-to-r from-brand-gold to-brand-gold-light shadow-lg hover:shadow-[0_4px_20px_rgba(212,168,67,0.4)] transition-all duration-200 hover:-translate-y-0.5">
            Ver Detalle Completo <i class="ri-arrow-right-line"></i>
          </a>
        </div>
      </div>
      <% } %>

        <!-- Nav Cards -->
        <div class="animate-in delay-100 flex flex-col gap-4">
          <p class="text-[15px] font-bold tracking-tight text-brand-navy">Mi Espacio</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <a href="/cliente/prestamo"
              class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex items-center gap-5 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-gold hover:shadow-[0_4px_20px_rgba(212,168,67,0.15)] group"
              id="card-mi-prestamo">
              <div
                class="w-[52px] h-[52px] shrink-0 rounded-[14px] flex items-center justify-center bg-brand-blue-light text-brand-blue group-hover:scale-105 transition-transform duration-300">
                <i class="ri-wallet-3-line text-[24px]"></i>
              </div>
              <div class="flex-1">
                <p class="text-[11px] font-semibold text-brand-muted uppercase tracking-[0.06em]">Préstamo</p>
                <p class="text-[16px] font-bold text-brand-navy mt-0.5 group-hover:text-brand-blue transition-colors">Mi
                  Préstamo</p>
                <p class="text-[12px] text-brand-muted mt-0.5">Detalle y cronograma de pagos</p>
              </div>
              <i
                class="ri-arrow-right-s-line text-[20px] text-brand-muted/50 group-hover:text-brand-gold transition-all group-hover:translate-x-1 duration-200"></i>
            </a>

            <a href="/cliente/perfil"
              class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex items-center gap-5 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-gold hover:shadow-[0_4px_20px_rgba(212,168,67,0.15)] group"
              id="card-mi-perfil">
              <div
                class="w-[52px] h-[52px] shrink-0 rounded-[14px] flex items-center justify-center bg-brand-gold-light text-brand-gold group-hover:scale-105 transition-transform duration-300">
                <i class="ri-user-settings-line text-[24px]"></i>
              </div>
              <div class="flex-1">
                <p class="text-[11px] font-semibold text-brand-muted uppercase tracking-[0.06em]">Perfil</p>
                <p class="text-[16px] font-bold text-brand-navy mt-0.5 group-hover:text-brand-gold transition-colors">Mi
                  Perfil</p>
                <p class="text-[12px] text-brand-muted mt-0.5">Actualiza tu información personal</p>
              </div>
              <i
                class="ri-arrow-right-s-line text-[20px] text-brand-muted/50 group-hover:text-brand-gold transition-all group-hover:translate-x-1 duration-200"></i>
            </a>
          </div>
        </div>

        <!-- Tabla de préstamos -->
        <% if (prestamos && prestamos.length> 0) { %>
          <div
            class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex flex-col overflow-hidden animate-in delay-200">
            <div
              class="px-7 py-5 border-b border-brand-border flex items-center justify-between gap-4 flex-wrap bg-white">
              <div>
                <p class="text-[16px] font-bold tracking-tight text-brand-navy">Historial de Préstamos</p>
                <p class="text-[13px] text-brand-muted mt-0.5">Todas tus operaciones registradas</p>
              </div>
            </div>
            <div class="w-full overflow-x-auto">
              <table class="w-full border-collapse text-left text-[13px]">
                <thead>
                  <tr class="bg-brand-surface border-b border-brand-border">
                    <th class="py-3.5 px-6 font-semibold text-brand-muted tracking-wide text-center">#</th>
                    <th class="py-3.5 px-6 font-semibold text-brand-muted tracking-wide text-right">Monto Solicitado
                    </th>
                    <th class="py-3.5 px-6 font-semibold text-brand-muted tracking-wide text-right">Cuota Total</th>
                    <th class="py-3.5 px-6 font-semibold text-brand-muted tracking-wide text-center">Tipo Pago</th>
                    <th class="py-3.5 px-6 font-semibold text-brand-muted tracking-wide text-center">Estado</th>
                    <th class="py-3.5 px-6 font-semibold text-brand-muted tracking-wide">Acción</th>
                  </tr>
                </thead>
                <tbody>
                  <% prestamos.forEach(p=> { %>
                    <tr
                      class="border-b border-brand-border last:border-b-0 hover:bg-brand-surface transition-colors duration-150">
                      <td class="py-3.5 px-6 text-center text-brand-muted font-medium">
                        <%= p.id %>
                      </td>
                      <td class="py-3.5 px-6 text-right font-medium text-brand-text">S/<%=
                          Number(p.monto).toLocaleString('es-MX', {minimumFractionDigits: 2}) %>
                      </td>
                      <td class="py-3.5 px-6 text-right font-bold text-brand-blue">S/<%=
                          Number(p.cuota).toLocaleString('es-MX', {minimumFractionDigits: 2}) %>
                      </td>
                      <td class="py-3.5 px-6 text-center">
                        <span
                          class="inline-flex items-center px-2 py-0.5 rounded-[6px] text-[11px] font-semibold <%= p.tipo_pago === 'mensual' ? 'bg-brand-success-light text-brand-success border border-brand-success' : 'bg-brand-blue-light text-brand-blue border border-brand-blue' %> capitalize">
                          <%= p.tipo_pago %>
                        </span>
                      </td>
                      <td class="py-3.5 px-6 text-center">
                        <% if (p.estado==='activo' ) { %>
                          <span
                            class="inline-flex items-center gap-1 px-2.5 py-1 rounded-[6px] text-[11px] font-semibold bg-brand-success-light text-brand-success border border-brand-success/30"><i
                              class="ri-flashlight-line"></i> Activo</span>
                          <% } else if (p.estado==='vencido' ) { %>
                            <span
                              class="inline-flex items-center gap-1 px-2.5 py-1 rounded-[6px] text-[11px] font-semibold bg-brand-danger-light text-brand-danger border border-brand-danger/30"><i
                                class="ri-alarm-warning-line"></i> Vencido</span>
                            <% } else if (p.estado==='pendiente' ) { %>
                              <span
                                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-[6px] text-[11px] font-semibold bg-amber-50 text-amber-600 border border-amber-200"><i
                                  class="ri-time-line"></i> Pendiente</span>
                              <% } else { %>
                                <span
                                  class="inline-flex items-center gap-1 px-2.5 py-1 rounded-[6px] text-[11px] font-semibold bg-brand-surface2 text-brand-muted border border-brand-border"><i
                                    class="ri-check-double-line"></i> Pagado</span>
                                <% } %>
                      </td>
                      <td class="py-3.5 px-6">
                        <a href="/cliente/prestamo?id=<%= p.id %>"
                          class="text-brand-blue hover:text-brand-blue-hover font-bold text-[12px] flex items-center gap-1">Ver
                          Detalle <i class="ri-arrow-right-line"></i></a>
                      </td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>
          <% } %>

            </div>
  </main>