<%- include('../partials/sidebar_cliente') %>

<main class="flex-1 h-screen overflow-y-auto bg-brand-bg relative flex flex-col min-w-0">

  <!-- Top Header -->
  <header class="flex items-center justify-between px-8 py-4 bg-white/92 backdrop-blur-md border-b border-brand-border sticky top-0 z-40">
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-brand-navy">Bienvenido, <%= cliente ? cliente.nombre.split(' ')[0] : user.name %></h1>
      <p class="text-[13px] text-brand-muted mt-0.5">Tu portal de préstamos hipotecarios</p>
    </div>
    <img src="<%= user.avatar %>" alt="Avatar" class="w-[38px] h-[38px] rounded-full border-2 border-brand-gold object-cover">
  </header>

  <div class="p-8 max-w-[1400px] mx-auto w-full flex-1 flex flex-col gap-6">

    <!-- Estado del préstamo -->
    <% if (!cliente) { %>
      <div class="bg-[#FFF4E5] border-l-[4px] border-l-orange-500 border-t border-r border-b border-t-orange-200 border-r-orange-200 border-b-orange-200 px-5 py-4 rounded-[12px] flex flex-col gap-1 transition-opacity duration-300 animate-in" id="alert-perfil">
        <p class="font-bold text-[14px] text-orange-800">Completa tu perfil</p>
        <p class="text-[13px] text-orange-700 opacity-90">Para acceder a todos los servicios, <a href="/cliente/perfil" class="font-bold hover:underline underline-offset-2">vincula tu cuenta aquí</a>.</p>
      </div>

    <% } else if (!prestamoActivo) { %>
      <div class="bg-brand-blue-light/50 border-l-[4px] border-l-brand-blue border-t border-r border-b border-t-brand-blue/20 border-r-brand-blue/20 border-b-brand-blue/20 px-5 py-4 rounded-[12px] flex flex-col gap-1 transition-opacity duration-300 animate-in" id="alert-sin-prestamo">
        <p class="font-bold text-[14px] text-brand-blue">Sin préstamos activos</p>
        <p class="text-[13px] text-brand-text opacity-90">Contacta a tu asesor para solicitar un préstamo hipotecario.</p>
      </div>

    <% } else { %>
      <!-- Hero Banner — Cuota Mensual -->
      <div class="bg-brand-navy rounded-[24px] p-8 text-white relative overflow-hidden shadow-[0_8px_30px_rgba(10,22,40,0.15)] flex flex-col sm:flex-row sm:items-center justify-between gap-6 animate-in" id="hero-prestamo">
        <div class="absolute -right-20 -top-20 w-80 h-80 bg-[radial-gradient(circle,rgba(212,168,67,0.2)_0%,transparent_70%)] pointer-events-none"></div>

        <div>
          <p class="text-[13px] font-bold uppercase tracking-widest text-brand-gold mb-2">📋 Tu cuota <%= prestamoActivo.tipo_pago %></p>
          <p class="text-[44px] font-extrabold tracking-tight leading-none mb-1">
            $<%= Number(prestamoActivo.cuota).toLocaleString('es-MX', {minimumFractionDigits: 2}) %>
            <span class="text-[20px] font-semibold text-white/50 ml-1">MXN</span>
          </p>
        </div>
        
        <div class="flex flex-wrap items-center gap-6 sm:gap-8 relative z-10">
          <div class="flex flex-col gap-1">
            <p class="text-[12px] font-medium text-white/50 uppercase tracking-wider">Monto del préstamo</p>
            <p class="text-[20px] font-bold text-white">$<%= Number(prestamoActivo.monto).toLocaleString('es-MX', {minimumFractionDigits: 2}) %></p>
          </div>
          <div class="w-px h-10 bg-white/10 hidden sm:block"></div>
          <div class="flex flex-col gap-1">
            <p class="text-[12px] font-medium text-white/50 uppercase tracking-wider">Plazo</p>
            <p class="text-[20px] font-bold text-white"><%= prestamoActivo.plazo_meses %> meses</p>
          </div>
          <div class="w-px h-10 bg-white/10 hidden sm:block"></div>
          <div class="flex flex-col gap-1">
            <p class="text-[12px] font-medium text-white/50 uppercase tracking-wider">Estado</p>
            <p class="text-[20px] font-bold text-brand-gold capitalize"><%= prestamoActivo.estado %></p>
          </div>
        </div>
        
        <div class="relative z-10 mt-4 sm:mt-0">
          <a href="/cliente/prestamo" class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg text-[13px] font-bold text-brand-navy bg-gradient-to-r from-brand-gold to-brand-gold-light hover:shadow-[0_4px_16px_rgba(212,168,67,0.4)] transition-all duration-200 hover:-translate-y-0.5" id="btn-ver-detalle">Ver Detalle Completo</a>
        </div>
      </div>
    <% } %>

    <!-- Nav Cards -->
    <div class="animate-in delay-100 flex flex-col gap-4">
      <p class="text-[15px] font-bold tracking-tight text-brand-navy">Mi Espacio</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <a href="/cliente/prestamo" class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex items-center gap-5 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-gold hover:shadow-[0_4px_20px_rgba(212,168,67,0.15)] group" id="card-mi-prestamo">
          <div class="w-[52px] h-[52px] shrink-0 rounded-2xl flex items-center justify-center bg-brand-blue-light text-brand-blue group-hover:scale-105 transition-transform duration-300">
            <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[11px] font-semibold text-brand-muted uppercase tracking-[0.06em]">Préstamo</p>
            <p class="text-[18px] font-bold text-brand-text mt-0.5 group-hover:text-brand-navy transition-colors">Mi Préstamo</p>
            <p class="text-[13px] text-brand-muted mt-0.5">Detalle y tabla de amortización</p>
          </div>
          <svg class="text-brand-muted/50 group-hover:text-brand-gold transition-colors group-hover:translate-x-1 duration-200" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </a>

        <a href="/cliente/perfil" class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex items-center gap-5 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-gold hover:shadow-[0_4px_20px_rgba(212,168,67,0.15)] group" id="card-mi-perfil">
          <div class="w-[52px] h-[52px] shrink-0 rounded-2xl flex items-center justify-center bg-brand-gold-light text-brand-gold group-hover:scale-105 transition-transform duration-300">
            <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[11px] font-semibold text-brand-muted uppercase tracking-[0.06em]">Perfil</p>
            <p class="text-[18px] font-bold text-brand-text mt-0.5 group-hover:text-brand-navy transition-colors">Mi Perfil</p>
            <p class="text-[13px] text-brand-muted mt-0.5">Actualiza tu información personal</p>
          </div>
          <svg class="text-brand-muted/50 group-hover:text-brand-gold transition-colors group-hover:translate-x-1 duration-200" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Tabla de préstamos -->
    <% if (prestamos && prestamos.length > 0) { %>
    <div class="bg-white rounded-[20px] shadow-[0_2px_8px_rgba(10,22,40,0.07)] border border-brand-border flex flex-col overflow-hidden animate-in delay-200">
      <div class="px-7 py-6 border-b border-brand-border flex items-center justify-between gap-4 flex-wrap bg-white">
        <div>
          <p class="text-[16px] font-bold tracking-tight text-brand-navy">Mis Préstamos</p>
          <p class="text-[13px] text-brand-muted mt-0.5">Historial de operaciones</p>
        </div>
      </div>
      <div class="w-full overflow-x-auto">
        <table class="w-full border-collapse text-left text-[13px]">
          <thead>
            <tr class="bg-brand-surface border-b border-brand-border">
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide">#</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-right">Monto</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-right">Cuota</th>
              <th class="py-3.5 px-5 font-semibold text-brand-muted tracking-wide text-center">Estado</th>
            </tr>
          </thead>
          <tbody>
            <% prestamos.forEach(p => { %>
            <tr class="border-b border-brand-border last:border-b-0 hover:bg-brand-surface transition-colors duration-150">
              <td class="py-3.5 px-5 text-brand-muted font-medium">#<%= p.id %></td>
              <td class="py-3.5 px-5 text-right font-medium text-brand-text">$<%= Number(p.monto).toLocaleString('es-MX', {minimumFractionDigits: 2}) %></td>
              <td class="py-3.5 px-5 text-right font-bold text-brand-blue">$<%= Number(p.cuota).toLocaleString('es-MX', {minimumFractionDigits: 2}) %></td>
              <td class="py-3.5 px-5 text-center">
                <% if (p.estado === 'activo') { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-[6px] text-[12px] font-semibold bg-brand-success-light text-brand-success border border-brand-success/30">Activo</span>
                <% } else if (p.estado === 'vencido') { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-[6px] text-[12px] font-semibold bg-brand-danger-light text-brand-danger border border-brand-danger/30">Vencido</span>
                <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-[6px] text-[12px] font-semibold bg-brand-surface2 text-brand-muted border border-brand-border">Pagado</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

  </div>
</main>
